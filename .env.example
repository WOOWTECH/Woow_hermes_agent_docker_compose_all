# Hermes Smart Home Assistant - Environment Variables
# Copy to .env and fill in real values before running deploy.sh

# Cloudflare (required for external access)
CF_API_TOKEN=your-cloudflare-api-token

# Domain
HERMES_DOMAIN=hermes-woowtechmag.woowtech.io

# Tunnel name (used to identify in Cloudflare dashboard)
TUNNEL_NAME=hermes

# PostgreSQL (auto-generated if not set)
# POSTGRES_PASSWORD=your-secure-password

# LLM Provider - Minimax
MINIMAX_API_KEY=your-minimax-api-key
