# =============================================================
# Hermes Agent Stack — Environment Variables
# =============================================================
# Copy to .env and fill in real values before deploying.
#
# K3s deployment: used by deploy/k3s/deploy.sh
# Podman deployment: used by deploy/podman/podman-compose.yml
# =============================================================

# --- Cloudflare (K3s only — required for external access) ---
CF_API_TOKEN=your-cloudflare-api-token

# --- Domain ---
HERMES_DOMAIN=hermes-woowtechmag.woowtech.io

# --- Tunnel name (Cloudflare dashboard identifier) ---
TUNNEL_NAME=hermes

# --- LLM Provider - Minimax ---
MINIMAX_API_KEY=your-minimax-api-key

# --- LLM Provider - OpenRouter (for GPT/GLM model routing) ---
OPENROUTER_API_KEY=your-openrouter-api-key

# --- Gateway API Key (auto-generated if not set) ---
API_SERVER_KEY=

# --- WebUI Password (CHANGE THIS!) ---
WEBUI_PASSWORD=CHANGEME_GENERATE_STRONG_PASSWORD

# --- Dashboard Basic Auth (CHANGE THIS!) ---
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=CHANGEME_GENERATE_STRONG_PASSWORD

# --- PostgreSQL (auto-generated if not set) ---
POSTGRES_PASSWORD=

# --- User/Group ID (container filesystem permissions) ---
HERMES_UID=1000
HERMES_GID=1000
