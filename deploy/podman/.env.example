# Hermes Agent Podman Stack — Environment Variables
# Copy to .env and fill in values before running podman-compose up

# --- LLM Provider Keys ---
MINIMAX_API_KEY=your-minimax-api-key
OPENROUTER_API_KEY=your-openrouter-api-key

# --- Gateway API Key (auto-generated if empty) ---
API_SERVER_KEY=

# --- WebUI / Dashboard Auth ---
WEBUI_PASSWORD=CHANGEME_GENERATE_STRONG_PASSWORD
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=CHANGEME_GENERATE_STRONG_PASSWORD

# --- PostgreSQL (auto-generated if empty) ---
POSTGRES_PASSWORD=

# --- Container User/Group ---
HERMES_UID=1000
HERMES_GID=1000

# --- MCP OAuth (required for Dashboard MCP OAuth flow) ---
# Set to the public URL of the Hermes Dashboard (port 9119)
# If not using Cloudflare Tunnel, use http://localhost:19119
HERMES_DASHBOARD_PUBLIC_URL=http://localhost:19119

# --- MCP Server API Keys (optional) ---
# Browserless: get from https://www.browserless.io/dashboard
# MCP_BROWSERLESS_MCP_API_KEY=your-browserless-api-key
